#export PATH="$PATH:$HOME/go/bin:/usr/local/go/bin:$HOME/.local/bin"
export PATH="/usr/lib/colorgcc/bin/:$HOME/.local/bin:$PATH:$HOME/bin:$HOME/bin/scripts"

export CCACHE_PATH="/usr/bin"

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# pacdiff: use meld
export DIFFPROG="meld"
export MERGEPROG="meld"

export LESS='-R -Q --use-color'

# In conjonction with ~/.config/systemd/user/ssh-agent.service
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"

# gpg signing
export GPG_TTY=$(tty)

export XDG_CACHE_HOME=$HOME/.cache
export XDG_CONFIG_HOME=$HOME/.config
export XDG_DATA_HOME=$HOME/.local/share
export XDG_STATE_HOME=$HOME/.local/state

export ZSH="$HOME/.oh-my-zsh"
